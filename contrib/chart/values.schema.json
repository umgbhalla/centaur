{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": { "type": "array" }
      }
    },
    "firewall": {
      "type": "object",
      "properties": {
        "trustedInternalHosts": { "type": "string" },
        "service": {
          "type": "object",
          "properties": {
            "proxyPort": { "type": "integer" },
            "controlPort": { "type": "integer" }
          }
        }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "bootstrapSecretName": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "sandboxBackend": { "type": "string" },
        "egressDiscovery": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "clusterDomain": { "type": "string" },
            "tailnetFqdnAnnotation": { "type": "string" }
          }
        }
      }
    },
    "overlay": {
      "type": "object",
      "properties": {
        "mountPath": { "type": "string" },
        "systemPrompt": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" },
            "sourcePath": { "type": "string" }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "runtimeClassName": { "type": "string" },
        "reposPath": { "type": "string" }
      }
    },
    "repoCache": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostPath": { "type": "string" },
        "repositories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "syncIntervalSeconds": { "type": "integer" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "githubToken": {
          "type": "object",
          "properties": {
            "existingSecretName": { "type": "string" },
            "secretKey": { "type": "string" },
            "token": { "type": "string" }
          }
        },
        "egressPorts": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "slackbot": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "runnerAccess": {
      "type": "object",
      "properties": {
        "allowedCidrs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "apiIngressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ingressControllerNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
