# =============================================================================
# Tempo AI v2 — Central Secrets File
# =============================================================================
# All plugin secrets can be defined here. Plugins inherit from this file.
# Per-plugin .env files can override specific values.
# Environment variables (Docker/k8s/sops/1pw) take final precedence.
# =============================================================================

# --- Core ---
DATABASE_URL=postgresql://tempo:tempo_dev@localhost:5432/ai_v2
OPENAI_API_KEY=
API_SECRET_KEY=

# --- Extractors (ETL pipeline) ---
POV_SLACK_TOKEN=
POV_SLACK_USER_TOKEN=
POV_LINEAR_API_KEY=
POV_GITHUB_TOKEN=
POV_GOOGLE_CLIENT_ID=
POV_GOOGLE_CLIENT_SECRET=
POV_GOOGLE_REFRESH_TOKEN=
POV_GOOGLE_SERVICE_ACCOUNT_KEY=
POV_GRANOLA_ACCESS_TOKEN=
POV_GRANOLA_ACCESS_TOKEN_2=
POV_GRANOLA_ENTERPRISE_API_KEY=
POV_ATTIO_API_KEY=
POV_PYLON_API_TOKEN=
POV_BETTERSTACK_API_TOKEN=

# --- Plugin Secrets ---

# Slack
SLACK_BOT_TOKEN=

# Linear
LINEAR_API_KEY=

# GSuite (Google Calendar, Drive, Gmail)
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TOKEN_JSON=

# Allium (on-chain analytics)
ALLIUM_API_KEY=

# CoinGecko
COINGECKO_API_KEY=

# Coin Metrics
COINMETRICS_API_KEY=

# Dune Analytics
DUNE_API_KEY=

# FalconX
FALCONX_API_KEY=
FALCONX_API_SECRET=
FALCONX_PASSPHRASE=

# Coinbase Prime
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_PASSPHRASE=
COINBASE_PORTFOLIO_ID=

# Anchorage Digital
ANCHORAGE_API_KEY=
ANCHORAGE_API_SECRET=

# BitGo
BITGO_ACCESS_TOKEN=
BITGO_ENTERPRISE_ID=

# Notion
NOTION_API_KEY=

# Nansen
NANSEN_API_KEY=

# PostHog
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=

# SimilarWeb
SIMILARWEB_API_KEY=

# Kalshi
KALSHI_API_KEY=

# Polymarket
POLYMARKET_API_KEY=

# Messari
MESSARI_API_KEY=

# DeFiLlama (no key needed — public API)

# Reshift (internal DB)
RESHIFT_DB_HOST=
RESHIFT_DB_PORT=
RESHIFT_DB_NAME=
RESHIFT_DB_USER=
RESHIFT_DB_PASSWORD=
RESHIFT_SSH_HOST=
RESHIFT_SSH_USER=
RESHIFT_SSH_KEY_PATH=

# Sandbox
SANDBOX_IMAGE=tempo-ai-sandbox:latest
GITHUB_REPOS=tempoxyz/tempo,tempoxyz/ai,tempoxyz/tempo-apps,tempoxyz/tempo-web,tempoxyz/ai-payments
